{
  "name": "hexcode",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "wasm:build": "wasm-pack build wasm/hexqr_decoder --target web --out-dir ../../src/wasm/hexqr_decoder",
    "build": "npm run wasm:build && tsc -b && vite build",
    "test": "vitest run",
    "pretest": "wasm-pack build wasm/hexqr_decoder --target web --out-dir ../../src/wasm/hexqr_decoder",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^1.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^8.0.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.0.0"
  }
